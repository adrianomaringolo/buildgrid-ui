  "conventions": {
    "classNameMerging": "cn() from @/lib/utils",
    "variantManagement": "cva() from class-variance-authority",
    "darkMode": "Every colour token must have a dark: counterpart",
    "dataSlot": "data-slot='…' attribute on every root element for external styling hooks",
    "newComponent": {
      "files": ["<name>.tsx", "<name>.stories.tsx", "<name>.test.tsx", "index.ts"],
      "barrelRegistration": "src/components/index.ts (alphabetical) or src/blocks/index.ts"
    }
